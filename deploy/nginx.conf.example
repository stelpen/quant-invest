# QuantInvest Nginx 配置示例
# 将此文件复制到 /etc/nginx/sites-available/quant-invest
# 然后 ln -s /etc/nginx/sites-available/quant-invest /etc/nginx/sites-enabled/

upstream quant_backend {
    server 127.0.0.1:8000;
}

server {
    listen 80;
    server_name your-domain.com;

    # 前端静态文件
    root /opt/quant-invest/frontend/dist;
    index index.html;

    # Gzip 压缩
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/plain text/css text/javascript application/json application/javascript;

    # API 反向代理
    location /api/ {
        proxy_pass http://quant_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket 支持
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # 超时设置（回测可能耗时较长）
        proxy_read_timeout 300s;
        proxy_connect_timeout 30s;
    }

    # 健康检查
    location /health {
        proxy_pass http://quant_backend;
    }

    # Vue Router History 模式
    location / {
        try_files $uri $uri/ /index.html;
    }

    # 静态资源缓存
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?)$ {
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    # 禁止访问隐藏文件
    location ~ /\. {
        deny all;
    }
}

# HTTPS 配置（使用 certbot 后取消注释）
# server {
