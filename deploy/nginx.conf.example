# QuantInvest Nginx 配置
# 适用于无域名环境（纯 IP 访问）
# 部署: cp deploy/nginx.conf.example /etc/nginx/conf.d/quant-invest.conf
#       nginx -t && systemctl reload nginx

upstream quant_backend {
    server 127.0.0.1:8000;
}

# ========== HTTP（纯 IP 访问）==========
server {
    listen 80 default_server;
    server_name _;  # 匹配任何 IP / 域名

    # 前端静态文件
    root /opt/quant-invest/frontend/dist;
    index index.html;

    # Gzip 压缩
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/plain text/css text/javascript application/json application/javascript;

    # API 反向代理
    location /api/ {
        proxy_pass http://quant_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket 支持
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # 超时设置（回测可能耗时较长）
        proxy_read_timeout 300s;
        proxy_connect_timeout 30s;
    }

    # 健康检查 + OpenAPI 文档
    location /health { proxy_pass http://quant_backend; }
    location /docs  { proxy_pass http://quant_backend; }
    location /redoc { proxy_pass http://quant_backend; }
    location /openapi.json { proxy_pass http://quant_backend; }

    # Vue Router History 模式
    location / {
        try_files $uri $uri/ /index.html;
    }

    # 静态资源缓存
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?)$ {
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    # 禁止访问隐藏文件
    location ~ /\. {
        deny all;
    }
}

# ========== HTTPS 自签名证书（可选，无域名方案）==========
# 生成自签名证书:
#   sudo mkdir -p /etc/nginx/ssl
#   sudo openssl req -x509 -nodes -days 3650 -newkey rsa:2048 \
#     -keyout /etc/nginx/ssl/quant.key \
#     -out /etc/nginx/ssl/quant.crt \
#     -subj "/CN=QuantInvest/O=Personal"
#
# 然后取消下面注释，把上面 HTTP server 块注释掉或改为 redirect:

# server {
#     listen 443 ssl http2 default_server;
#     server_name _;
#
#     ssl_certificate     /etc/nginx/ssl/quant.crt;
#     ssl_certificate_key /etc/nginx/ssl/quant.key;
#     ssl_protocols       TLSv1.2 TLSv1.3;
#     ssl_ciphers         HIGH:!aNULL:!MD5;
